# Copy this file to .env.local and fill in real values.
# .env.local is gitignored - never commit real keys.
# In production, set these in your deploy host's environment-variable settings.

# Required - your Resend API key (server-side only; never exposed to the browser)
RESEND_API_KEY=

# Required for newsletter storage - the Resend audience subscribers are added to
RESEND_AUDIENCE_ID=

# Optional overrides (defaults are baked into lib/email.js)
# RESEND_FROM=The 100 CR Leader <noreply@the100croreleader.com>
# ADMIN_EMAIL=info@touchmarkdes.com
# REPLY_TO=info@touchmarkdes.com

# Optional - point the front-end forms at a different endpoint (defaults: /api/contact, /api/subscribe)
# VITE_CONTACT_ENDPOINT=/api/contact
# VITE_SUBSCRIBE_ENDPOINT=/api/subscribe

# Cloudflare Turnstile - guards the booking form ONLY (newsletter has no captcha).
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
#   VITE_TURNSTILE_SITE_KEY - public site key (exposed to the browser)
#   TURNSTILE_SECRET_KEY    - secret key (server-side only; never exposed)
# Leave both blank to disable the captcha. Cloudflare's "always passes" test keys:
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
