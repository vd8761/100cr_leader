{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/foundation/**",
              "components/media/**",
              "components/navigation/**",
              "components/typography/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color - use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value - use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Bebas Neue|Onest))/i]",
        "message": "Font not provided by the design system. Available: Bebas Neue, Onest."
      },
      {
        "selector": "JSXOpeningElement[name.name='AudioPlayer'] > JSXAttribute > JSXIdentifier[name!=/^(?:seed|current|total|progress|defaultPlaying|style|key|ref|className|style|children)$/]",
        "message": "<AudioPlayer> doesn't accept that prop. Declared props: seed, current, total, progress, defaultPlaying, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:forest|sand|outline|gold)$/]",
        "message": "<Badge> tone must be one of 'forest' | 'sand' | 'outline' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|href|onClick|icon|iconRight|size|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, href, onClick, icon, iconRight, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|onDark|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'solid' | 'onDark' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DisplayHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|color|align|as|style|key|ref|className|style|children)$/]",
        "message": "<DisplayHeading> doesn't accept that prop. Declared props: children, size, color, align, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DisplayHeading'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:hero|stacked|md)$/]",
        "message": "<DisplayHeading> size must be one of 'hero' | 'stacked' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DisplayHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DisplayHeading> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EpisodeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:episode|title|teaser|duration|date|current|total|progress|defaultPlaying|seed|style|key|ref|className|style|children)$/]",
        "message": "<EpisodeCard> doesn't accept that prop. Declared props: episode, title, teaser, duration, date, current, total, progress, defaultPlaying, seed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Marquee'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|icon|tone|speed|style|key|ref|className|style|children)$/]",
        "message": "<Marquee> doesn't accept that prop. Declared props: text, icon, tone, speed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Marquee'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<Marquee> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|active|tone|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<NavBar> doesn't accept that prop. Declared props: items, active, tone, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<NavBar> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlatformIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:platform|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<PlatformIcon> doesn't accept that prop. Declared props: platform, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlatformPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:platform|tone|action|style|key|ref|className|style|children)$/]",
        "message": "<PlatformPill> doesn't accept that prop. Declared props: platform, tone, action, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlatformPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<PlatformPill> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|tone|rule|style|key|ref|className|style|children)$/]",
        "message": "<SectionLabel> doesn't accept that prop. Declared props: children, icon, tone, rule, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<SectionLabel> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:platform|href|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<SocialIcon> doesn't accept that prop. Declared props: platform, href, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialIcon'] > JSXAttribute[name.name='platform'] > Literal[value!=/^(?:linkedin|facebook|x|instagram|whatsapp)$/]",
        "message": "<SocialIcon> platform must be one of 'linkedin' | 'facebook' | 'x' | 'instagram' | 'whatsapp'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialIcon'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<SocialIcon> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|progress|seed|playing|count|color|playedColor|height|style|key|ref|className|style|children)$/]",
        "message": "<Waveform> doesn't accept that prop. Declared props: variant, progress, seed, playing, count, color, playedColor, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:hero|track)$/]",
        "message": "<Waveform> variant must be one of 'hero' | 'track'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
